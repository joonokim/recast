<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow JIT for the JavaScript engine inside Electron -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Babel standalone transforms code at runtime; needs unsigned exec memory -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Allow spawning external binaries (whisper, claude) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Needed so spawned child processes inherit entitlements -->
  <key>com.apple.security.inherit</key>
  <true/>
  <!-- File dialogs + drag-drop -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  <!-- If you later add mic recording inside the app itself -->
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
